from core_contracts import Message

def triage(msg: Message) -> str:
    text = msg.text.strip().lower()

    if text.startswith('/'):
        print(f"🎯 L3 Triage: [COMMAND]")
        return "command"

    feedback_words = {"ok", "thanks", "good", "stop", "yes", "no"}
    words = text.split()
    if len(words) <= 2 and any(w in feedback_words for w in words):
        print(f"🎯 L3 Triage: [FEEDBACK]")
        return "feedback"

    print(f"🎯 L3 Triage: [INQUIRY]")
    return "inquiry"

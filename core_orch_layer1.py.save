import core_orch_layer3
import os
import uuid
import time
import threading
import core_orch_layer2
import httpx
from dataclasses import dataclass, field
from typing import Optional, List, Dict, Any, Set

# Import from our previous file
from core_orch_layer0 import LIMITER, OWNER_ID

@dataclass
class Message:
    cid: str
    msg_id: int
    text: str
    intent_id: str = field(default_factory=lambda: str(uuid.uuid4()))
    username: str = "unknown"
    ts: float = field(default_factory=time.time)

_PROCESSING_LOCKS: Set[str] = set()
_gate_mutex = threading.Lock()

def manage_gate(cid: str, action: str = "open") -> bool:
    with _gate_mutex:
        if action == "open":
            if cid in _PROCESSING_LOCKS: return False
            _PROCESSING_LOCKS.add(cid)
            return True
        else:
            _PROCESSING_LOCKS.discard(cid)
            return True

def poll_forever():
    token = os.getenv("TELEGRAM_TOKEN")
    offset = 0
    print("🚀 L1: Polling Started...")
    
    with httpx.Client(timeout=30.0) as client:
        while True:
            if not LIMITER.consume():
                time.sleep(0.1)
                continue
            try:
                url = f"https://api.telegram.org/bot{token}/getUpdates"
                r = client.get(url, params={"offset": offset, "timeout": 20})
                updates = r.json().get("result", [])
                for upd in updates:
                    offset = upd["update_id"] + 1
                    _handle_update(upd)
            except Exception as e:
                print(f"⚠️ L1 Error: {e}")
                time.sleep(5)

def _handle_update(upd: Dict[str, Any]):
    m = upd.get("message")
    if not m or str(m["chat"]["id"]) != OWNER_ID:
        return

    msg = Message(
        cid=str(m["chat"]["id"]),
        msg_id=m["message_id"],
        text=m.get("text", ""),
        username=m.get("from", {}).get("username", "unknown")
    )

    if manage_gate(msg.cid, "open"):
        print(f"📥 L1: Accepted {msg.msg_id}")
        
        # 1. Record in Memory
        core_orch_layer2.commit_to_memory(msg)
        
        # 2. Triage the Message (NEW)
        intent = core_orch_layer3.triage(msg)
        
        # 3. Decision Branching
        if intent == "command":
            print("🚀 L3 -> L6: Routing to Command Handler (Pending)")
        elif intent == "inquiry":
            print("🧠 L3 -> L4: Routing to Reasoning Engine (Pending)")
            
        manage_gate(msg.cid, "close")


if __name__ == "__main__":
    poll_forever()

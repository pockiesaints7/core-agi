        "confidence": "float8",
        "expires_at": "timestamptz",
        "created_at": "timestamptz",
        "updated_at": "timestamptz"
      },
      "enums": {
        "domain": ["auth","code","failure_recovery","github","groq","local_pc","oracle_vm","postgres","powershell","project","reasoning","supabase","telegram","universal","zapier"]
      },
      "constraints": {
        "priority": "1-10 integer",
        "confidence": "0.0-1.0 float (NOT enum -- different from knowledge_base)"
      },
      "notes": "confidence here is FLOAT 0.0-1.0, NOT the enum used in knowledge_base. id=1 is PROBE row -- never query or modify."
    },
